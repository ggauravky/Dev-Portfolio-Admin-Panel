# Backend Environment Variables
# Copy this file to .env for local development
# For production, set these in Render dashboard

PORT=5000
MONGO_URI=your_mongodb_connection_string_here
# Optional: override Node DNS servers used for mongodb+srv resolution
# DNS_SERVERS=1.1.1.1,8.8.8.8
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
ADMIN_EMAIL=admin@portfolio.com
ADMIN_PASSWORD=Admin@123

# IMPORTANT: Set this to your Vercel frontend URL for production
# Example: https://ggauravkyadmin.vercel.app
FRONTEND_URL=http://localhost:5173

NODE_ENV=development
READ_ONLY_MODE=false
